# Consolidated local environment template for Profytron
# Copy the relevant values from here into apps/api/.env.local and apps/web/.env.local,
# or use this as a single reference file while filling in your own secrets locally.

# =========================
# Shared URLs
# =========================
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# =========================
# API / Backend
# =========================
NODE_ENV=development
PORT=4000
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
CORS_ORIGIN=http://localhost:3000

# =========================
# Frontend / Web
# =========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
BACKEND_API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/trading
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_ENABLE_MOCK_API=false
NEXT_PUBLIC_VITALS_ENDPOINT=
PLAYWRIGHT_BASE_URL=http://localhost:3000

# =========================
# Database / Redis
# =========================
DATABASE_URL=YOUR_DATABASE_URL
DIRECT_URL=YOUR_DIRECT_URL
UPSTASH_REDIS_REST_URL=YOUR_UPSTASH_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN
REDIS_URL=YOUR_REDIS_URL
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL_TEST=YOUR_REDIS_URL_TEST
DATABASE_URL_TEST=YOUR_DATABASE_URL_TEST
API_TEST_WITH_INFRA=true

# =========================
# Auth / JWT / Encryption
# =========================
JWT_ACCESS_SECRET=YOUR_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET
LEGACY_JWT_SECRET=YOUR_LEGACY_JWT_SECRET
AES_MASTER_KEY=YOUR_AES_MASTER_KEY

# =========================
# Supabase
# =========================
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWKS_URL=YOUR_SUPABASE_JWKS_URL
SUPABASE_JWT_KID=YOUR_SUPABASE_JWT_KID
SUPABASE_JWT_JWK=YOUR_SUPABASE_JWT_JWK

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

# =========================
# Firebase / Notifications
# =========================
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID
FIREBASE_PRIVATE_KEY=YOUR_FIREBASE_PRIVATE_KEY
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@profytron-c0c0d.iam.gserviceaccount.com

# =========================
# Payments
# =========================
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
RAZORPAY_KEY_ID=DEMO_KEY
RAZORPAY_KEY_SECRET=DEMO_SECRET
RAZORPAY_WEBHOOK_SECRET=DEMO_WEBHOOK

# =========================
# Email
# =========================
RESEND_API_KEY=YOUR_RESEND_API_KEY

# =========================
# AI / Market Data
# =========================
AI_SERVICE_URL=http://localhost:8000
BACKTEST_SERVICE_URL=http://localhost:8001
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_API_KEY=YOUR_TWELVE_DATA_API_KEY
HUGGING_FACE_API_KEY=YOUR_HUGGING_FACE_API_KEY
ALPHA_VANTAGE_API_KEY=YOUR_ALPHA_VANTAGE_API_KEY
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
MARKET_ALLOW_SYNTHETIC_FALLBACK=false

# =========================
# AWS / Bedrock
# =========================
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=YOUR_AWS_BEARER_TOKEN_BEDROCK
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_INFERENCE_MAX_TOKENS=2048
# =========================
# Monitoring / Ops
# =========================
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=http://localhost:4000/v1/auth/github/callback
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
AI_COACH_URL=http://localhost:8001
SENTRY_DSN=
API_SUPERVISOR_MAX_RESTARTS=20

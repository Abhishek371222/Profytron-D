# =============================================================================
# PROFYTRON ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control
# =============================================================================

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
NODE_ENV=development

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
PORT=4000
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
FRONTEND_DASHBOARD_URL=http://localhost:3000/dashboard
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Production / cloud (Neon, Supabase, etc.) — must be reachable from your machine
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Local dev (after: docker compose up -d postgres && npx prisma migrate deploy)
# DATABASE_URL=postgresql://postgres:postgress_password@localhost:5432/profytron_local
# DIRECT_URL=postgresql://postgres:postgress_password@localhost:5432/profytron_local

# =============================================================================
# REDIS (Upstash or Standard Redis)
# =============================================================================
# Option 1: Upstash Redis (Production recommended)
# REST credentials (for HTTP-based tools only — NOT for ioredis/BullMQ):
UPSTASH_REDIS_REST_URL=https://[YOUR-INSTANCE].upstash.io
UPSTASH_REDIS_REST_TOKEN=[YOUR-UPSTASH-TOKEN]
# Wire-protocol URL for the API (copy from Upstash dashboard → Redis → Connect):
# REDIS_URL=rediss://default:[YOUR-UPSTASH-TOKEN]@[YOUR-INSTANCE].upstash.io:6379

# Option 2: Standard Redis connection
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# AUTHENTICATION - JWT Secrets (CRITICAL: Generate secure values!)
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=[GENERATE-SECURE-64-CHAR-STRING]
JWT_REFRESH_SECRET=[GENERATE-SECURE-64-CHAR-STRING]
LEGACY_JWT_SECRET=[GENERATE-SECURE-64-CHAR-STRING]

# JWT Expiration (optional, defaults apply if not set)
# JWT_ACCESS_EXPIRES=24h
# JWT_REFRESH_EXPIRES=7d

# AES Master Key for broker credential encryption (MUST be exactly 64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this key requires re-encrypting stored broker credentials — plan a migration script before changing it in production.
AES_MASTER_KEY=[GENERATE-64-CHAR-HEX-STRING]

# =============================================================================
# SUPABASE
# =============================================================================
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SUPABASE-SERVICE-ROLE-KEY]
SUPABASE_JWKS_URL=https://[YOUR-PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_KID=[YOUR-JWT-KID]
SUPABASE_JWT_JWK={"kty":"EC","kid":"[YOUR-KID]","crv":"P-256","x":"[YOUR-X]","y":"[YOUR-Y]","alg":"ES256"}

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
GOOGLE_CLIENT_ID=[YOUR-GOOGLE-CLIENT-ID].apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=[YOUR-GOOGLE-CLIENT-SECRET]
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback

# =============================================================================
# GITHUB OAUTH (Optional)
# =============================================================================
GITHUB_CLIENT_ID=[YOUR-GITHUB-CLIENT-ID]
GITHUB_CLIENT_SECRET=[YOUR-GITHUB-CLIENT-SECRET]
GITHUB_CALLBACK_URL=http://localhost:4000/v1/auth/github/callback

# =============================================================================
# FIREBASE (Optional - for push notifications)
# =============================================================================
FIREBASE_API_KEY=[YOUR-FIREBASE-API-KEY]
FIREBASE_AUTH_DOMAIN=[YOUR-PROJECT].firebaseapp.com
FIREBASE_PROJECT_ID=[YOUR-PROJECT-ID]
FIREBASE_STORAGE_BUCKET=[YOUR-PROJECT].firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=[YOUR-SENDER-ID]
FIREBASE_APP_ID=[YOUR-APP-ID]
FIREBASE_MEASUREMENT_ID=G-[YOUR-MEASUREMENT-ID]
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@[YOUR-PROJECT-ID].iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
# Test keys (use sk_test_*/pk_test_* for development)
STRIPE_SECRET_KEY=sk_test_[YOUR-STRIPE-SECRET-KEY]
STRIPE_PUBLISHABLE_KEY=pk_test_[YOUR-STRIPE-PUBLISHABLE-KEY]
STRIPE_WEBHOOK_SECRET=whsec_[YOUR-STRIPE-WEBHOOK-SECRET]

# Optional: Set currency (default: usd)
# STRIPE_CURRENCY=usd

# =============================================================================
# RAZORPAY (Optional - alternative payment processor)
# =============================================================================
RAZORPAY_KEY_ID=[YOUR-RAZORPAY-KEY-ID]
RAZORPAY_KEY_SECRET=[YOUR-RAZORPAY-KEY-SECRET]
RAZORPAY_WEBHOOK_SECRET=[YOUR-RAZORPAY-WEBHOOK-SECRET]

# =============================================================================
# AI WORKFORCE (event-driven agents)
# =============================================================================
AGENTS_ENABLED=true
AGENTS_LOW_USAGE=true
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# =============================================================================
# BROKER INTEGRATION (MetaAPI.cloud — MT4/MT5 demo & live linking)
# =============================================================================
# Get a free token at https://metaapi.cloud (free tier: up to 5 accounts).
# Dashboard -> "API access token". REQUIRED for real broker connections;
# leave blank to run in MOCK mode (fake balances, no real broker link).
# Admin master MT5 (for: npx ts-node scripts/setup-master-copy.ts)
ADMIN_MT5_LOGIN=
ADMIN_MT5_PASSWORD=
ADMIN_MT5_SERVER=MetaQuotes-Demo
ADMIN_MT5_PLATFORM=mt5
MASTER_COPY_STRATEGY_NAME=Profytron Master Bot
MASTER_COPY_MONTHLY_PRICE=49
MASTER_COPY_ANNUAL_PRICE=399

# Use MetaAPI CopyFactory for trade mirroring (recommended). Set false to use legacy polling.
COPYFACTORY_ENABLED=true
COPYFACTORY_MAX_TRADE_RISK=0.1

METAAPI_TOKEN=
# Optional region pin: new-york | vint-hill | london | singapore. Blank = auto.
METAAPI_REGION=
# DB id of the operator's master BrokerAccount (set after first connect).
MASTER_BROKER_ACCOUNT_ID=

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_[YOUR-RESEND-API-KEY]

# =============================================================================
# INTERNAL SERVICES
# =============================================================================
AI_SERVICE_URL=http://localhost:8000
BACKTEST_SERVICE_URL=http://localhost:8001

# =============================================================================
# MARKET DATA (Twelve Data)
# =============================================================================
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
TWELVE_DATA_API_KEY=[YOUR-TWELVE-DATA-API-KEY]

# =============================================================================
# HUGGING FACE (Optional - for AI features)
# =============================================================================
HUGGING_FACE_API_KEY=hf_[YOUR-HUGGING-FACE-API-KEY]

# =============================================================================
# TELEGRAM BOT (Optional)
# =============================================================================
# Set the same value in your Telegram setWebhook secret_token parameter
TELEGRAM_WEBHOOK_SECRET=[YOUR-TELEGRAM-WEBHOOK-SECRET]

# =============================================================================
# TESTING CONFIGURATION (Do not use in production)
# =============================================================================
# NODE_ENV=test
# API_TEST_WITH_INFRA=true
# FRONTEND_URL=https://app-test.profytron.example
# CORS_ORIGIN=https://app-test.profytron.example

generator client {
  provider      = "prisma-client-js"
  // Explicitly target the Alpine (musl) engine built against OpenSSL 3.x so the
  // runtime image (node:20-alpine, OpenSSL 3) loads the correct query engine.
  // Without this, `prisma generate` can fall back to the OpenSSL 1.1 musl engine
  // and fail at runtime with "libssl.so.1.1: No such file or directory".
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS
enum MarketRegime {
  TRENDING
  RANGING
  VOLATILE
  UNKNOWN
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionTier {
  FREE
  PRO
  ELITE
  BUSINESS
  INSTITUTIONAL
}

enum BrokerName {
  PAPER
  MT4
  MT5
  BINANCE
  BYBIT
  KUCOIN
  INTERACTIVE_BROKERS
}

enum StrategyCategory {
  TREND
  SCALPING
  RANGE
  VOLATILITY
  ARBITRAGE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  EXPERT
}

enum AssetClass {
  Forex
  Crypto
  Indices
  Commodities
  Stocks
}

enum Timeframe {
  M1
  M3
  M5
  M15
  H1
  H4
  D1
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PROVISIONING
  FAILED
  CANCELLED
  EXPIRED
  PAUSED
  BLOCKED
}

enum SubscriptionBillingModel {
  FIXED
  PROFIT_SHARE
}

enum ProfitShareState {
  PROFIT_SHARE_OK
  PROFIT_SHARE_DUE
  PROFIT_SHARE_PAUSED
  PROFIT_SHARE_SETTLING
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SUBSCRIPTION_PAYMENT
  TRADING_PNL
  COMMISSION
  MARKETPLACE_SALE
  PROFIT_SHARE_DEBIT
  PROFIT_SHARE_LOSS_CREDIT
}

enum ProfitShareLedgerStatus {
  PENDING
  COLLECTED
  CREDITED
  WRITTEN_OFF
}

enum TransactionDirection {
  IN
  OUT
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum AffiliateTier {
  STARTER
  PRO
  ELITE
}

enum AffiliateFunnelEventType {
  CLICK
  SIGNUP
  CONVERSION
  PAYOUT
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  CRYPTO
  STRIPE
  PAYPAL
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum StrategyNodeType {
  ENTRY
  EXIT
  INDICATOR
  CONDITION
  ACTION
}

enum VpsProvider {
  AWS
  DIGITALOCEAN
  LINODE
  VULTR
  GCP
  CUSTOM
}

enum BotStatus {
  RUNNING
  STOPPED
  ERROR
  PAUSED
}

// MODELS
model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String?
  fullName            String
  username            String?          @unique
  avatarUrl           String?
  bio                 String?
  country             String           @default("IN")
  timezone            String           @default("Asia/Kolkata")
  role                UserRole         @default(USER)
  kycStatus           KycStatus        @default(NOT_STARTED)
  subscriptionTier    SubscriptionTier @default(FREE)
  riskProfileJson     Json?
  riskDnaScore        Float?
  referralCode        String           @unique @default(uuid())
  googleId            String?          @unique
  emailVerified       Boolean          @default(false)
  isActive            Boolean          @default(true)
  isSuspended         Boolean          @default(false)
  onboardingCompleted Boolean          @default(false)
  lastLoginAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  brokerAccounts                  BrokerAccount[]
  createdStrategies               Strategy[]                 @relation("CreatedStrategies")
  subscriptions                   UserStrategySubscription[]
  trades                          Trade[]
  walletTransactions              WalletTransaction[]
  achievements                    UserAchievement[]
  notifications                   Notification[]
  notificationPreference          NotificationPreference?
  affiliateRecord                 Affiliate?                 @relation("UserAffiliate")
  referrals                       Affiliate[]                @relation("ReferrerAffiliate")
  affiliateFunnelEventsAsReferrer AffiliateFunnelEvent[]     @relation("AffiliateFunnelReferrer")
  affiliateFunnelEventsAsReferee  AffiliateFunnelEvent[]     @relation("AffiliateFunnelReferee")
  reviews                         StrategyReview[]
  auditLogs                       AuditLog[]
  kycDocuments                    KycDocument[]
  sessions                        UserSession[]
  fcmTokens                       UserFcmToken[]
  leaderboardEntries              LeaderboardEntry[]

  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json?

  payments                Payment[]
  invoices                Invoice[]
  paidSubscriptions       UserSubscription[]
  traderProfile           TraderProfile?
  socialComments          SocialComment[]
  supportTickets          SupportTicket[]
  supportResponses        SupportTicketResponse[]
  strategyBuilders        StrategyBuilder[]
  vpsAccounts             VpsAccount[]
  aiRiskPolicy            AiRiskPolicy?
  userPreferences         UserPreference?
  brokerCredentials       BrokerApiCredential[]
  tradeJournalEntries     TradeJournalEntry[]
  apiKeys                 ApiKey[]
  activationEvents        UserActivationEvent[]
  masterProfile           MasterProfile?
  followerRelationships   CopyRelationship[]      @relation("FollowerRelationships")
  coachConversations      CoachConversation[]
  coachMessagesSent       CoachMessage[]          @relation("CoachMessageSender")
  coachEscalations        CoachEscalation[]       @relation("CoachEscalationUser")
  coachEscalationsClaimed CoachEscalation[]       @relation("CoachEscalationClaimedBy")

  @@index([email])
  @@index([referralCode])
}

model UserActivationEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     String
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([userId, event])
  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String
  deviceName   String?
  browser      String?
  ipAddress    String?
  country      String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([deviceId])
}

model BrokerAccount {
  id                   String     @id @default(uuid())
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  brokerName           BrokerName
  accountNumberLast4   String
  credentialsEncrypted String
  /// SHA-256 of the one-time bridge EA token (plaintext returned only on connect/rotate).
  bridgeTokenHash      String?    @unique
  serverName           String?
  isPaperTrading       Boolean    @default(false)
  isDefault            Boolean    @default(false)
  isMasterSource       Boolean    @default(false)
  isActive             Boolean    @default(true)
  initialEquity        Float?
  lastConnectedAt      DateTime?
  connectedAt          DateTime   @default(now())
  createdAt            DateTime   @default(now())

  subscriptions       UserStrategySubscription[]
  trades              Trade[]
  masterForStrategies Strategy[]                 @relation("StrategyMasterAccount")
  masterProfile       MasterProfile?
  bridgeOrders        CopyBridgeOrder[]

  @@index([userId])
  @@index([isMasterSource])
}

model Strategy {
  id                    String             @id @default(uuid())
  creatorId             String
  creator               User               @relation("CreatedStrategies", fields: [creatorId], references: [id])
  name                  String
  description           String             @db.Text
  category              StrategyCategory
  riskLevel             RiskLevel
  assetClass            AssetClass?
  timeframe             Timeframe?
  configJson            Json
  isPublished           Boolean            @default(false)
  verificationStatus    VerificationStatus @default(UNVERIFIED)
  isVerified            Boolean            @default(false)
  biasCheckJson         Json?
  monthlyPrice          Float?
  annualPrice           Float?
  lifetimePrice         Float?
  maxCopies             Int                @default(500)
  copiesCount           Int                @default(0)
  totalRevenue          Float              @default(0)
  isFeatured            Boolean            @default(false)
  masterBrokerAccountId String?
  masterBrokerAccount   BrokerAccount?     @relation("StrategyMasterAccount", fields: [masterBrokerAccountId], references: [id], onDelete: SetNull)
  copyFactoryStrategyId String?
  reviewStartedAt       DateTime?
  reviewEndsAt          DateTime?
  reviewNotes           String?            @db.Text
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  performance    StrategyPerformance[]
  subscriptions  UserStrategySubscription[]
  trades         Trade[]
  listing        MarketplaceListing?
  reviews        StrategyReview[]
  aiExplanations AITradeExplanation[]
  documents      StrategyDocument[]

  @@index([creatorId])
  @@index([category])
  @@index([isPublished, isVerified])
}

model StrategyPerformance {
  id            String   @id @default(uuid())
  strategyId    String
  strategy      Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  winRate       Float
  drawdown      Float
  maxDrawdown   Float
  sharpeRatio   Float
  sortinoRatio  Float?
  totalTrades   Int
  winningTrades Int
  netPnl        Float
  equityCurve   Json
  createdAt     DateTime @default(now())

  @@unique([strategyId, date])
  @@index([strategyId, date])
}

model UserStrategySubscription {
  id                          String                   @id @default(uuid())
  userId                      String
  user                        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategyId                  String
  strategy                    Strategy                 @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  brokerAccountId             String?
  brokerAccount               BrokerAccount?           @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)
  status                      SubscriptionStatus       @default(INACTIVE)
  provisioningJob             ProvisioningJob?
  planType                    String?
  billingModel                SubscriptionBillingModel @default(FIXED)
  profitSharePct              Float?
  equityBaselineAtSubscribe   Float?
  profitShareAccruedUnsettled Float?
  profitShareState            ProfitShareState?
  lastProfitCheckAt           DateTime?
  lastProfitPingAt            DateTime?
  stripeSubId                 String?
  stripeItemId                String?
  trialEndsAt                 DateTime?
  subscribedAt                DateTime                 @default(now())
  expiresAt                   DateTime?
  cancelledAt                 DateTime?
  riskOverrideEnabled         Boolean                  @default(false)
  maxDrawdownPct              Float?
  excludedSymbolsJson         Json?
  slippageBps                 Float                    @default(0)
  executionPriority           Int                      @default(0)
  latencyLimitMs              Int?
  lastLatencyMs               Int?
  lastExecutionAt             DateTime?
  riskPolicyJson              Json?
  executionProfileJson        Json?
  lotMultiplier               Float                    @default(1.0)
  profitShareLedgerEntries    ProfitShareLedgerEntry[]

  @@unique([userId, strategyId])
  @@index([userId, status])
  @@index([strategyId])
  @@index([expiresAt])
  @@index([billingModel, status])
  @@index([profitShareState])
}

model Trade {
  id                    String              @id @default(uuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id])
  strategyId            String?
  strategy              Strategy?           @relation(fields: [strategyId], references: [id])
  brokerAccountId       String?
  brokerAccount         BrokerAccount?      @relation(fields: [brokerAccountId], references: [id])
  brokerTicket          String?
  symbol                String
  direction             TradeDirection
  volume                Float
  openPrice             Float
  closePrice            Float?
  stopLoss              Float?
  takeProfit            Float?
  profit                Float?
  commission            Float               @default(0)
  swap                  Float               @default(0)
  isPaper               Boolean             @default(false)
  status                TradeStatus         @default(OPEN)
  openedAt              DateTime            @default(now())
  closedAt              DateTime?
  requestedPrice        Float?
  fillPrice             Float?
  slippageBps           Float               @default(0)
  executionLatencyMs    Int?
  icebergSliceIndex     Int?
  icebergSliceCount     Int?
  executionMode         String?
  executionMetadataJson Json?
  aiExplanation         AITradeExplanation?
  socialComments        SocialComment[]
  journalEntry          TradeJournalEntry?

  @@index([userId, status])
  @@index([userId, closedAt])
  @@index([userId, openedAt])
  @@index([strategyId])
  @@index([strategyId, status])
  @@index([strategyId, openedAt])
  @@index([brokerAccountId])
  @@index([brokerTicket])
  @@index([symbol])
  @@index([openedAt])
}

model WalletTransaction {
  id                       String                   @id @default(uuid())
  userId                   String
  user                     User                     @relation(fields: [userId], references: [id])
  type                     TransactionType
  direction                TransactionDirection
  amount                   Float
  balanceAfter             Float
  status                   TransactionStatus        @default(PENDING)
  /// Canonical support ID: PRF-WLT-YYYYMMDD-XXXXXXXX — unique, immutable after create
  billingId                String                   @unique
  /// Human-readable payment category captured at transaction time
  paymentCategory          String?
  /// Payer / sending account address (user or company)
  senderAddress            String?
  /// Payee / receiving account address (user or company)
  receiverAddress          String?
  /// Gateway / bank transaction reference when available
  externalTxnId            String?
  reference                String?
  idempotencyKey           String                   @unique
  description              String?
  metadataJson             Json?
  stripePaymentId          String?
  razorpayOrderId          String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  supportTickets           SupportTicket[]
  profitShareLedgerEntries ProfitShareLedgerEntry[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([idempotencyKey])
  @@index([billingId])
  @@index([externalTxnId])
}

model ProfitShareLedgerEntry {
  id                  String                   @id @default(uuid())
  subscriptionId      String
  subscription        UserStrategySubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  periodStart         DateTime                 @db.Date
  periodEnd           DateTime                 @db.Date
  netPnl              Float
  companySharePct     Float
  companyShareAmount  Float
  status              ProfitShareLedgerStatus  @default(PENDING)
  settledAt           DateTime?
  walletTransactionId String?
  walletTransaction   WalletTransaction?       @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([subscriptionId, periodStart, periodEnd])
  @@index([subscriptionId, periodEnd])
  @@index([status, periodEnd])
  @@index([walletTransactionId])
}

model MarketplaceListing {
  id               String    @id @default(uuid())
  strategyId       String    @unique
  strategy         Strategy  @relation(fields: [strategyId], references: [id])
  monthlyPrice     Float
  annualPrice      Float
  lifetimePrice    Float
  isFeatured       Boolean   @default(false)
  totalRevenue     Float     @default(0)
  trialDays        Int       @default(7)
  maxCopies        Int       @default(500)
  creatorSharePct  Float     @default(0.8)
  platformSharePct Float     @default(0.2)
  payoutEnabled    Boolean   @default(true)
  lastPayoutAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isFeatured])
  @@index([isFeatured, updatedAt])
}

model Affiliate {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation("UserAffiliate", fields: [userId], references: [id])
  referrerId      String?
  referrer        User?         @relation("ReferrerAffiliate", fields: [referrerId], references: [id])
  tier            AffiliateTier @default(STARTER)
  commissionRate  Float         @default(0.30)
  totalEarned     Float         @default(0)
  totalPaid       Float         @default(0)
  clickCount      Int           @default(0)
  signupCount     Int           @default(0)
  conversionCount Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([referrerId])
}

model AffiliateFunnelEvent {
  id         String                   @id @default(uuid())
  referrerId String
  referrer   User                     @relation("AffiliateFunnelReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId  String?
  referee    User?                    @relation("AffiliateFunnelReferee", fields: [refereeId], references: [id], onDelete: SetNull)
  eventType  AffiliateFunnelEventType
  amount     Float                    @default(0)
  sourceRef  String?                  @unique
  createdAt  DateTime                 @default(now())

  @@index([referrerId, createdAt])
  @@index([referrerId, eventType])
}

model UserAchievement {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementKey String
  tier           AchievementTier
  unlockedAt     DateTime        @default(now())
  metadataJson   Json?

  @@unique([userId, achievementKey])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  category  String           @default("SYSTEM")
  priority  String           @default("NORMAL")
  title     String
  body      String
  icon      String?
  actionUrl String?
  isRead    Boolean          @default(false)
  isSeen    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, category])
}

model NotificationPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inAppEnabled      Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  securityAlerts    Boolean  @default(true)
  tradingAlerts     Boolean  @default(true)
  paymentAlerts     Boolean  @default(true)
  systemAlerts      Boolean  @default(true)
  marketingAlerts   Boolean  @default(false)
  accountAlerts     Boolean  @default(true)
  quietHoursEnabled Boolean  @default(false)
  quietHoursStart   String   @default("22:00")
  quietHoursEnd     String   @default("07:00")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model NotificationLog {
  id               String   @id @default(uuid())
  notificationId   String?
  userId           String
  channel          String
  status           String   @default("SENT")
  providerResponse Json?
  sentAt           DateTime @default(now())

  @@index([userId, sentAt])
  @@index([notificationId])
  @@index([channel, status])
}

model StrategyReview {
  id           String   @id @default(uuid())
  strategyId   String
  strategy     Strategy @relation(fields: [strategyId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  rating       Int      @db.SmallInt
  reviewText   String   @db.Text
  creatorReply String?  @db.Text
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([strategyId, userId])
  @@index([strategyId])
  @@index([userId])
}

model AITradeExplanation {
  id              String    @id @default(uuid())
  tradeId         String    @unique
  trade           Trade     @relation(fields: [tradeId], references: [id])
  strategyId      String?
  strategy        Strategy? @relation(fields: [strategyId], references: [id])
  summary         String
  confidenceScore Int
  riskFactorsJson Json
  keyLevelsJson   Json
  createdAt       DateTime  @default(now())

  @@index([strategyId])
}

model KycDocument {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  docType     String
  status      KycStatus @default(PENDING)
  storagePath String
  onfidoId    String?
  notes       String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  @@index([userId])
}

model UserFcmToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model LeaderboardEntry {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period       String
  rank         Int
  winRate      Float    @default(0)
  totalPnl     Float    @default(0)
  sharpeRatio  Float    @default(0)
  totalTrades  Int      @default(0)
  profitFactor Float    @default(0)
  maxDrawdown  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([userId, period])
  @@index([period, rank])
}

model AuditLog {
  id          String   @id @default(uuid())
  eventType   String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  detailsJson Json
  triggeredBy String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([eventType])
}

// ===== PAYMENT SYSTEM =====
model Payment {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount            Float
  currency          String        @default("INR")
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  stripePaymentId   String?       @unique
  description       String?
  metadataJson      Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?

  invoice      Invoice?
  subscription UserSubscription?

  @@index([userId, status])
  @@index([status, createdAt])
}

model Invoice {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId       String    @unique
  payment         Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceNumber   String    @unique
  amount          Float
  tax             Float     @default(0)
  total           Float
  currency        String    @default("INR")
  description     String?
  items           Json
  pdfUrl          String?
  downloadedCount Int       @default(0)
  issuedAt        DateTime  @default(now())
  dueAt           DateTime?

  @@index([userId, issuedAt])
  @@index([invoiceNumber])
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?  @db.Text
  monthlyPrice    Float
  annualPrice     Float?
  features        Json
  maxStrategies   Int      @default(10)
  maxCopyTrades   Int      @default(50)
  prioritySupport Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions UserSubscription[]

  @@index([name])
}

model UserSubscription {
  id            String             @id @default(uuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId        String
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id])
  paymentId     String?            @unique
  payment       Payment?           @relation(fields: [paymentId], references: [id])
  status        SubscriptionStatus @default(ACTIVE)
  billingCycle  String             @default("MONTHLY")
  autoRenewal   Boolean            @default(true)
  razorpaySubId String?            @unique
  subscribedAt  DateTime           @default(now())
  expiresAt     DateTime
  cancelledAt   DateTime?
  nextBillingAt DateTime?

  @@unique([userId, planId])
  @@index([status, expiresAt])
}

// ===== SOCIAL TRADING =====
model TraderProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?  @db.Text
  headline         String?
  followers        Int      @default(0)
  following        Int      @default(0)
  totalTrades      Int      @default(0)
  winRate          Float    @default(0)
  avgRr            Float    @default(0)
  totalPnl         Float    @default(0)

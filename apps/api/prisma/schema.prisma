// ===== COPY TRADING DOMAIN MODEL =====
// Additive, first-class data model for the master/follower copy system.
// Existing copy flow (Strategy + UserStrategySubscription + JSON metadata)
// continues to work; these tables add queryable master profiles, explicit
// master↔follower relationships, an append-only event log, and a
// master-ticket → follower-ticket execution map.

enum CopySizingMode {
  FIXED
  MULTIPLIER
  EQUITY_RATIO
}

enum CopyRelationshipStatus {
  ACTIVE
  PAUSED
  STOPPED
}

enum TradeEventType {
  SIGNAL_RECEIVED
  POSITION_OPENED
  POSITION_MODIFIED
  POSITION_CLOSED
  RISK_BLOCKED
  EXECUTION_FAILED
}

enum ExecutionStatus {
  PENDING
  FILLED
  FAILED
  CLOSED
}

model MasterProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  brokerAccountId     String?  @unique
  displayName         String
  bio                 String?  @db.Text
  strategyDescription String?  @db.Text
  isPublic            Boolean  @default(true)
  isVerified          Boolean  @default(false)
  followersCount      Int      @default(0)
  roiPct              Float    @default(0)
  maxDrawdownPct      Float    @default(0)
  winRate             Float    @default(0)
  sharpeRatio         Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  brokerAccount BrokerAccount?     @relation(fields: [brokerAccountId], references: [id], onDelete: SetNull)
  relationships CopyRelationship[]

  @@index([userId])
  @@index([isPublic, isVerified])
}

model CopyRelationship {
  id                String                 @id @default(uuid())
  masterProfileId   String
  followerUserId    String
  subscriptionId    String?                @unique
  followerAccountId String?
  status            CopyRelationshipStatus @default(ACTIVE)
  sizingMode        CopySizingMode         @default(MULTIPLIER)
  lotMultiplier     Float                  @default(1.0)
  fixedLot          Float?
  maxDrawdownPct    Float?
  dailyLossLimitUsd Float?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  masterProfile MasterProfile    @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)
  follower      User             @relation("FollowerRelationships", fields: [followerUserId], references: [id], onDelete: Cascade)
  executions    TradeExecution[]

  @@unique([masterProfileId, followerUserId])
  @@index([masterProfileId, status])
  @@index([followerUserId])
}

// Append-only event log for the copy lifecycle. Intentionally not FK-bound to
// User/Trade so it stays a cheap, high-throughput write path.
model TradeEvent {
  id               String         @id @default(uuid())
  type             TradeEventType
  masterProfileId  String?
  masterAccountId  String?
  masterPositionId String?
  userId           String?
  tradeId          String?
  symbol           String?
  side             String?
  volume           Float?
  price            Float?
  stopLoss         Float?
  takeProfit       Float?
  detailsJson      Json?
  createdAt        DateTime       @default(now())

  @@index([masterPositionId])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// Maps each master position to the resulting follower execution(s).
model TradeExecution {
  id                 String          @id @default(uuid())
  copyRelationshipId String?
  followerUserId     String
  followerTradeId    String?         @unique
  masterPositionId   String?
  masterTicket       String?
  followerTicket     String?
  symbol             String
  side               String
  requestedVolume    Float
  filledVolume       Float?
  requestedPrice     Float?
  fillPrice          Float?
  slippageBps        Float           @default(0)
  latencyMs          Int?
  status             ExecutionStatus @default(PENDING)
  errorReason        String?         @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  copyRelationship CopyRelationship? @relation(fields: [copyRelationshipId], references: [id], onDelete: SetNull)

  @@index([masterPositionId])
  @@index([followerUserId, createdAt])
  @@index([status])
}

/// Live copy signals for user MT5 terminals (bridge EA) — no MetaApi seat required.
model CopyBridgeOrder {
  id               String        @id @default(uuid())
  userId           String
  brokerAccountId  String
  brokerAccount    BrokerAccount @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  followerTradeId  String?
  masterPositionId String?
  action           String // OPEN | CLOSE | MODIFY
  symbol           String
  side             String? // BUY | SELL
  volume           Float
  price            Float?
  stopLoss         Float?
  takeProfit       Float?
  status           String        @default("PENDING") // PENDING | CLAIMED | FILLED | FAILED | CANCELLED
  brokerTicket     String?
  errorReason      String?       @db.Text
  claimedAt        DateTime?
  filledAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([brokerAccountId, status])
  @@index([userId, status])
  @@index([masterPositionId])
  @@index([followerTradeId])
  @@index([status, createdAt])
}

model StrategyDocument {
  id            String   @id @default(uuid())
  strategyId    String
  strategy      Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  title         String
  description   String?  @db.Text
  kind          String   @default("PDF") // IMAGE | PDF | DATA
  storageKey    String
  mimeType      String   @default("application/pdf")
  fileSizeBytes Int
  sortOrder     Int      @default(0)
  isPublished   Boolean  @default(true)
  uploadedBy    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([strategyId, isPublished, sortOrder])
  @@index([strategyId, kind])
}

model ProvisioningJob {
  id             String                   @id @default(uuid())
  subscriptionId String                   @unique
  subscription   UserStrategySubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  status         String                   @default("PENDING")
  attempts       Int                      @default(0)
  lastError      String?                  @db.Text
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([status, createdAt])
}

model PaymentIdempotency {
  idempotencyKey String   @id
  paymentId      String?
  status         String
  responseJson   Json?
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

model EmailLog {
  id        String   @id @default(uuid())
  userId    String?
  to        String
  subject   String
  type      String
  status    String   @default("SENT")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([to, createdAt])
  @@index([type, createdAt])
}

// ===== ALPHA COACH =====
enum CoachConversationStatus {
  ACTIVE
  ESCALATED
  CLOSED
}

enum CoachMessageRole {
  USER
  ASSISTANT
  EXECUTIVE
  SYSTEM
}

enum CoachMessageSource {
  FAQ
  AI
  HUMAN
  SYSTEM
}

enum CoachEscalationStatus {
  OPEN
  CLAIMED
  RESOLVED
}

model CoachConversation {
  id        String                  @id @default(uuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String                  @default("New coaching session")
  status    CoachConversationStatus @default(ACTIVE)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  messages    CoachMessage[]
  escalations CoachEscalation[]

  @@index([userId, updatedAt])
  @@index([status])
}

model CoachMessage {
  id             String             @id @default(uuid())
  conversationId String
  conversation   CoachConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           CoachMessageRole
  content        String             @db.Text
  source         CoachMessageSource @default(SYSTEM)
  faqAnswerId    String?
  faqAnswer      CoachFaqAnswer?    @relation(fields: [faqAnswerId], references: [id], onDelete: SetNull)
  senderId       String?
  sender         User?              @relation("CoachMessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model CoachFaqAnswer {
  id        String   @id @default(uuid())
  category  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions CoachFaqQuestion[]
  messages  CoachMessage[]

  @@index([category])
}

model CoachFaqQuestion {
  id         String         @id @default(uuid())
  answerId   String
  answer     CoachFaqAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  question   String
  normalized String
  keywords   String[]
  createdAt  DateTime       @default(now())

  @@index([answerId])
  @@index([normalized])
}

model CoachEscalation {
  id             String                @id @default(uuid())
  conversationId String
  conversation   CoachConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                  @relation("CoachEscalationUser", fields: [userId], references: [id], onDelete: Cascade)
  status         CoachEscalationStatus @default(OPEN)
  claimedById    String?
  claimedBy      User?                 @relation("CoachEscalationClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  priority       Int                   @default(0)
  /// When an executive is expected to reply (default: createdAt + 15 minutes).
  slaDeadline    DateTime?
  claimedAt      DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([userId])
  @@index([conversationId])
  @@index([claimedById])
}

# =============================================================================
# PROFYTRON WEB APPLICATION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# NEVER commit .env files to version control
# =============================================================================

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NODE_ENV=development

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================
# Both vars needed: SENTRY_DSN for server-side, NEXT_PUBLIC_SENTRY_DSN for browser
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Localhost for development. For production deploy, set these to your hosted
# API (e.g. https://profytron-api.onrender.com). Your PC can be off — the cloud
# hosts the API, Neon DB, and MetaAPI sync.
# Use same-origin /api in dev (Next.js rewrites to backend /v1)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
BACKEND_API_ORIGIN=http://localhost:4000

# WebSocket base URL — client appends /trading namespace (no suffix here)
# Production: same host as BACKEND (wss://your-api.example.com)
NEXT_PUBLIC_WS_URL=http://localhost:4000

# =============================================================================
# SUPABASE (Client-side)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[YOUR-SUPABASE-PUBLISHABLE-KEY]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]

# =============================================================================
# STRIPE (Client-side publishable key only!)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_[YOUR-STRIPE-PUBLISHABLE-KEY]
# Razorpay publishable key id (public). NEVER put the key secret in the frontend.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_[YOUR-RAZORPAY-KEY-ID]

# =============================================================================
# ANALYTICS (PostHog)
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# MOCK API (Development only)
# =============================================================================
# Set to "true" to use MSW mocks instead of real API calls
NEXT_PUBLIC_ENABLE_MOCK_API=false

# =============================================================================
# WEB VITALS (Optional - for performance monitoring)
# =============================================================================
# NEXT_PUBLIC_VITALS_ENDPOINT=https://your-vitals-collector.com/vitals

# =============================================================================
# PLAYWRIGHT E2E TESTING
# =============================================================================
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# =============================================================================
# OAUTH DIAGNOSTICS (Development only)
# =============================================================================
# Used by /oauth-diagnostics page for debugging OAuth flows
# These are read-only diagnostic values

# =============================================================================
# SERVER-SIDE LIVE TRADING (Next.js API routes — never expose to browser)
# =============================================================================
# Required for /api/broker/accounts, /api/trading/trades/*, /api/analytics/portfolio
# Copy the same values from apps/api/.env for local development.
# DATABASE_URL=
# AES_MASTER_KEY=
# METAAPI_TOKEN=
# FINNHUB_API_KEY=
# TWELVE_DATA_API_KEY=

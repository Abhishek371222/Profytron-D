# =============================================================================
# PROFYTRON WEB APPLICATION ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# NEVER commit .env files to version control
# =============================================================================

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL (should point to your NestJS API)
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
BACKEND_API_ORIGIN=http://localhost:4000

# WebSocket URL for real-time trading updates
NEXT_PUBLIC_WS_URL=ws://localhost:4000/trading

# =============================================================================
# SUPABASE (Client-side)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=[YOUR-SUPABASE-PUBLISHABLE-KEY]
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]

# =============================================================================
# STRIPE (Client-side publishable key only!)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_[YOUR-STRIPE-PUBLISHABLE-KEY]

# =============================================================================
# MOCK API (Development only)
# =============================================================================
# Set to "true" to use MSW mocks instead of real API calls
NEXT_PUBLIC_ENABLE_MOCK_API=false

# Set to "true" only when you explicitly want demo UI banners/mode.
# Keep false for production-like real user experience.
NEXT_PUBLIC_DEMO_MODE=false

# =============================================================================
# WEB VITALS (Optional - for performance monitoring)
# =============================================================================
# NEXT_PUBLIC_VITALS_ENDPOINT=https://your-vitals-collector.com/vitals

# =============================================================================
# PLAYWRIGHT E2E TESTING
# =============================================================================
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# =============================================================================
# OAUTH DIAGNOSTICS (Development only)
# =============================================================================
# Used by /oauth-diagnostics page for debugging OAuth flows
# These are read-only diagnostic values

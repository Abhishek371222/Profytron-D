{
  "name": "profytron-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:ai": "cd services/ai && python main.py",
    "dev:backtest": "cd services/backtest && python main.py",
    "dev:all": "concurrently \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:full": "concurrently \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:ai\" \"pnpm dev:backtest\"",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:seed": "pnpm --filter api prisma db seed",
    "db:studio": "pnpm --filter api prisma studio",
    "db:reset": "pnpm --filter api prisma migrate reset --force && pnpm db:seed",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  }
}

# Claude Code local settings — contains shell history that may include secrets
.claude/settings.local.json

# Environment files (NEVER commit these)
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local
apps/api/.env
apps/api/.env.*
apps/api/.env.test
apps/web/.env

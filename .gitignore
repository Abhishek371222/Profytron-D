# local.env.example is a developer convenience file — contains real credentials
local.env.example

# Exception: Keep example files
!apps/api/.env.example
!apps/web/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Dev server output dumps
api-out.txt
api-err.txt
web-out.txt
web-err.txt

# Firebase service-account keys (NEVER commit — contain private keys)
*firebase-adminsdk*.json
**/serviceAccount*.json

# Generated from apps/web/scripts/firebase-messaging-sw.template.js by
# apps/web/scripts/generate-firebase-sw.mjs (runs via predev/prebuild) —

# Root-level shared defaults
# Copy values into apps/api/.env and apps/web/.env.local as needed.
# NOTE: Replace all <PLACEHOLDER> values with real credentials in your local .env files.
# Never commit real credentials.

# Public URLs
APP_URL=https://profytron.app
API_URL=https://api.profytron.app

# Frontend
NEXT_PUBLIC_APP_URL=https://profytron.app
NEXT_PUBLIC_FRONTEND_URL=https://profytron.app
NEXT_PUBLIC_BACKEND_URL=https://api.profytron.app
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=https://api.profytron.app
PLAYWRIGHT_BASE_URL=https://profytron.app

# Backend
API_PUBLIC_URL=https://api.profytron.app
FRONTEND_URL=https://profytron.app
CORS_ORIGIN=https://profytron.app

# Data stores (Neon PostgreSQL + Upstash Redis)
# Neon: DATABASE_URL = pooled host (*-pooler.*); DIRECT_URL = direct host (no -pooler) for migrations
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<NEON-POOLER-HOST>/<DATABASE>?sslmode=require
DIRECT_URL=postgresql://<USER>:<PASSWORD>@<NEON-DIRECT-HOST>/<DATABASE>?sslmode=require
REDIS_URL=rediss://default:<UPSTASH_TOKEN>@<INSTANCE>.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://<INSTANCE>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<UPSTASH_TOKEN>

# Testing
API_TEST_WITH_INFRA=true
DATABASE_URL_TEST=postgresql://<USER>:<PASSWORD>@<HOST>:5432/<DATABASE>?schema=public
REDIS_URL_TEST=rediss://default:<UPSTASH_PASSWORD>@<UPSTASH_HOST>:6379
